# =============================================================================
# iDone Chatbot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=iDone-Chatbot
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=idone_chatbot
DB_USER=postgres
DB_PASSWORD=postgres_password_change_me

# Database URL (alternative to individual settings)
# DATABASE_URL=postgresql://postgres:postgres_password_change_me@postgres:5432/idone_chatbot

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=  # Optional: set if Qdrant requires authentication

# -----------------------------------------------------------------------------
# LLM Configuration (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# LLM Configuration (Groq) - Optional alternative to OpenAI
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Frontend (Admin Dashboard)
# -----------------------------------------------------------------------------
ADMIN_API_KEY=admin_secret_key_change_me

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://chat.idone.co.il,https://n8n.idone.co.il,https://www.idone.co.il,https://idone.co.il

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Docker Network (for NPM integration)
# -----------------------------------------------------------------------------
DOCKER_NETWORK=npm_network
