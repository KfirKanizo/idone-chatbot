# =============================================================================
# iDone Chatbot - Local Development Environment
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=iDone-Chatbot
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=idone_chatbot
DB_USER=postgres
DB_PASSWORD=postgres_dev_password

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# LLM Configuration (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# LLM Configuration (Groq) - Optional alternative to OpenAI
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Frontend (Admin Dashboard)
# -----------------------------------------------------------------------------
ADMIN_API_KEY=admin_dev_key

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Docker Network
# -----------------------------------------------------------------------------
DOCKER_NETWORK=npm_network
